# copy to `.env` and fill in. .env is gitignored.

S3_BUCKET=tinfoil-demo-579421472636-us-east-2-an
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=..
AWS_SECRET_ACCESS_KEY=..

# pace each sim step (ms). 20ms ≈ 3.3 min total run. set to 0 to flat-out finish in seconds.
STEP_DELAY_MS=20

# resume options — leave commented for a fresh run
# RUN_ID=
# RESUME_FROM_CHECKPOINT=2
